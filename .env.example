# doubleagent —— 模型源配置示例（复制为 .env，填入自己的 key；.env 绝不进 git）
# 模型层用 @earendil-works/pi-ai，运行时只配国产源 / Gemini 反代，绝不调 OpenAI/Anthropic。
#
# 任选其一填写；也可在应用「设置」面板里粘贴，存本地 userData（推荐给电脑小白）。

# DeepSeek（原生支持）
# DEEPSEEK_API_KEY=

# MiniMax（原生支持）
# MINIMAX_API_KEY=

# 智谱 GLM / ZAI（原生支持）
# ZAI_API_KEY=

# Kimi / Moonshot（原生支持）
# MOONSHOT_API_KEY=

# 通义千问 DashScope（走 OpenAI 兼容 baseURL）
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Gemini 反代（OpenAI 格式，走 OpenAI 兼容 baseURL）
# GEMINI_PROXY_API_KEY=
# GEMINI_PROXY_BASE_URL=
